{
  "name": "gh-api-client",
  "version": "1.1.0",
  "description": "A lightweight Java client for the GitHub API that simplifies common operations such as listing repositories, branches, commits, collaborators, and files, with built-in support for token-based authentication.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": {
    "name": "Ivan",
    "email": "pilmee@gmail.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "docs": "typedoc",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "github",
    "api",
    "client",
    "repositories",
    "branches",
    "commits",
    "collaborators",
    "files",
    "pull requests",
    "github api client",
    "github api wrapper",
    "github api library"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ElJijuna/github-api-client",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/github-api-client.git"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/github-api-client/issues"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "semantic-release": "^24.2.9",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typedoc": "^0.27.9",
    "typescript": "^5.8.3"
  }
}
